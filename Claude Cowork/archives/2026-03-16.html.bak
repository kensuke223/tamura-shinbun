<script>
document.addEventListener("DOMContentLoaded",function(){
var gs=["linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%)","linear-gradient(135deg,#2d1b69 0%,#11998e 100%)","linear-gradient(135deg,#0c0c0c 0%,#333 50%,#1a1a1a 100%)","linear-gradient(135deg,#cc0000 0%,#660000 100%)","linear-gradient(135deg,#003d5b 0%,#00838f 100%)","linear-gradient(135deg,#4a148c 0%,#7b1fa2 100%)"];
var i=0;
document.querySelectorAll("img").forEach(function(img){
function fix(){
var d=document.createElement("div");
d.className=img.className+" img-fallback";
d.style.background=gs[i%gs.length];
var t=img.alt||"";
if(t.length>20)t=t.substring(0,20)+"…";
d.textContent=t;
img.parentNode.replaceChild(d,img);
i++;
}
img.addEventListener("error",fix);
if(img.complete&&img.naturalWidth===0&&img.src)fix();
});
});
</script>
</body>
</html>
