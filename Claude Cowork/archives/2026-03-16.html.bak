    .vol-badge{background:#cc0000;color:#fff;font-size:10px;font-weight:900;padding:2px 8px;border-radius:2px;display:inline-block;margin-bottom:5px;letter-spacing:.1em;}
    .issue-num{font-size:10px;color:#aaa;}
    .date-bar{display:flex;justify-content:space-between;align-items:center;padding:6px 14px;background:#f5f0e6;border-bottom:3px solid #cc0000;font-size:9px;color:#666;}
    .archive-btn{background:#111;color:#fff;font-size:9px;font-weight:700;padding:2px 8px;border-radius:2px;text-decoration:none;}

    /* TICKER */
    .ticker-wrap{background:#cc0000;overflow:hidden;padding:7px 0;}
    .ticker-inner{display:flex;animation:ticker 40s linear infinite;}
    .ticker-item{white-space:nowrap;color:#fff;font-size:11px;font-weight:700;padding:0 30px;letter-spacing:.05em;}
    @keyframes ticker{0%{transform:translateX(100vw);}100%{transform:translateX(-100%);}}

    /* SECTIONS */
    .sec-head{background:#111;color:#fff;padding:8px 14px;font-size:12px;font-weight:900;letter-spacing:.1em;margin-top:10px;}
    .sec-head span{color:#cc0000;}

    /* STORY CARDS */
    .story-card{background:#fff;margin:2px 0;}
    .story-img{width:100%;object-fit:cover;display:block;}
    .story-img.hero{height:220px;}
    .story-img.main{height:180px;}
    .story-img.half{height:130px;}
    .story-body{padding:12px 14px;}
    .story-tag{display:inline-block;background:#cc0000;color:#fff;font-size:9px;font-weight:900;padding:1px 6px;border-radius:2px;margin-bottom:6px;letter-spacing:.08em;}
    .story-tag.blue{background:#0066cc;}
    .story-tag.green{background:#006600;}
    .story-tag.orange{background:#cc6600;}
    .story-tag.purple{background:#660099;}
    .story-h{font-size:17px;font-weight:900;line-height:1.35;margin-bottom:6px;}
    .story-h.hero-h{font-size:22px;}
    .story-h.small-h{font-size:13px;}
    .story-p{font-size:12px;color:#444;line-height:1.6;}
    .source-url{font-size:10px;color:#888;margin-top:8px;word-break:break-all;}
    .story-link{text-decoration:none;color:inherit;display:block;}
    .story-link:hover .story-body{background:#fffaf5;}

    /* HALF GRID */
    .half-grid{display:flex;gap:2px;margin:0;}
    .half-card{flex:1;background:#fff;}
    .half-link{text-decoration:none;color:inherit;display:block;}
    .half-link:hover .story-body{background:#fffaf5;}

    /* QUOTE BOX */
    .quote-box{background:#111;color:#fff;margin:2px 0;padding:16px 14px;}
    .quote-mark{font-size:36px;color:#cc0000;line-height:1;font-weight:900;}
    .quote-text{font-size:14px;font-weight:700;line-height:1.5;margin:6px 0;}
    .quote-src{font-size:10px;color:#aaa;margin-top:4px;}

    /* ALERT BAR */
    .alert-bar{background:#ffdd00;border-left:5px solid #cc0000;padding:8px 14px;margin:2px 0;font-size:11px;font-weight:700;color:#111;}

    /* RANKING */
    .ranking-list{background:#fff;margin:2px 0;padding:6px 0;}
    .rank-item{display:flex;align-items:center;padding:8px 14px;border-bottom:1px solid #f0ebe0;}
    .rank-item:last-child{border-bottom:none;}
    .rank-num{font-size:22px;font-weight:900;color:#cc0000;min-width:36px;line-height:1;}
    .rank-num.gold{color:#cc9900;}
    .rank-num.silver{color:#888;}
    .rank-num.bronze{color:#c07030;}
    .rank-word{font-size:13px;font-weight:700;flex:1;}
    .rank-move{font-size:10px;font-weight:700;}
    .rank-move.up{color:#cc0000;}
    .rank-move.new{color:#0066cc;}

    /* NUMBER BAR */
    .num-bar{background:#fff;margin:2px 0;padding:12px 14px;display:flex;gap:0;}
    .num-item{flex:1;text-align:center;border-right:1px solid #f0ebe0;}
