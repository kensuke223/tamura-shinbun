    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#f0ebe0;color:#111;font-family:'Noto Sans JP','Hiragino Kaku Gothic ProN',sans-serif;font-size:14px;line-height:1.6;max-width:480px;margin:0 auto;}

    /* MASTHEAD */
    .masthead-banner{background:#111;padding:14px 14px 12px;display:flex;align-items:flex-end;justify-content:space-between;}
    .paper-title{font-size:44px;font-weight:900;letter-spacing:-.02em;line-height:1;}
